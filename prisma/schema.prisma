generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. 机场核心枢纽
// ==========================================
model Airport {
  id           String       @id @default(cuid())
  iata         String       @unique // 三字码，全大写，全局唯一，例如: JFK
  iataCode     String?       @unique // 全小写，用于 URL 路由和大小写不敏感查询，例如: jfk
  name         String
  city         String
  country      String       @default("USA")
  slug         String       @unique // 人可读 slug，例如: jfk-new-york

  // SEO & 流量分配
  isPopular    Boolean      @default(false) // 是否为顶级枢纽（展示在首页/目录页头部）
  isActive     Boolean      @default(true)  // 软删除：设为 false 隐藏但不物理删除
  searchVolume Int?         // 月搜索量（用于 A-Z 目录的自动排序）

  // 关联的停车场矩阵
  parkings     ParkingLot[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([isActive])
  @@index([isPopular])
  @@index([searchVolume])
}

// ==========================================
// 2. 停车场比价矩阵（The Money Maker）
// ==========================================
model ParkingLot {
  id              String   @id @default(cuid())
  airport         Airport  @relation(fields: [airportIataCode], references: [iataCode], onDelete: Cascade)
  airportIataCode String        // 关联到 Airport.iataCode（小写），避免大小写问题

  // 基础信息
  name            String   // 停车场名称（如：The Parking Spot）
  slug            String   @unique // 唯一路由 slug（如：the-parking-spot-lax）
  type            String   // 极其重要: 'OFFICIAL'（官方高价）或 'OFF_SITE'（私人低价）
  featured        Boolean  @default(false) // 是否在首页/详情页置顶推荐
  isActive        Boolean  @default(true)  // 软删除：设为 false 隐藏但不物理删除

  // 核心比价数据（Decimal 精度，用于前端极速渲染和排序）
  dailyRate       Decimal  // 日均最低价，例如: 12.50，Decimal 确保货币计算零舍入误差
  distanceMiles   Float?   // 距离航站楼英里数
  shuttleMins     Int?     // 班车时间（分钟），例如: 5

  // 设施与服务标签（存储 JSON 字符串，SQLite 本身不支持数组类型）
  tags            String?  // 特色标签，存 JSON 字符串，如: '["Best Value", "Covered"]'

  // 设施与服务布尔标识
  isIndoor        Boolean  @default(false) // 是否室内/有顶棚
  hasValet        Boolean  @default(false)  // 是否代客泊车
  is24Hours       Boolean  @default(true)  // 是否 24 小时营业

  // 详情页扩展字段
  address         String?  // 详细地址
  shuttleFrequency String? // 班车频率，如 "Every 20-35 mins"
  shuttleHours    String?  // 班车运营时间，如 "4:00 AM - 12:00 AM"
  arrivalDirections String? // 到达路线指引（JSON格式，分方向）
  thingsToKnow    String?  // 注意事项列表（JSON格式）

  // 信任背书（前端 UI 需要的星级评分）
  rating          Float?   // 评分，例如: 4.8
  reviewCount     Int?     // 评论数，例如: 1240

  // 💰 联盟分佣通道
  affiliateUrl    String?  // 跳转到 Way.com / SpotHero 的联盟分佣链接

  // 爬虫溯源标记
  dataSource      String?  // 数据来源（如：spothero, way.com, official）
  rawContent      String?  // AI 提取前的原始抓取文本（备查）
  lastCheckedAt   DateTime? // 价格最后爬取时间，SEO 页面可显示"数据更新时间: 2026-04-07"

  // 软删除
  deletedAt       DateTime? // 设为时间戳即软删除，保留历史关联数据

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([airportIataCode])
  @@index([type])
  @@index([dailyRate])
  @@index([featured])
  @@index([isActive])
  @@index([deletedAt])
}
