generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 服务类型常量（SQLite 不支持枚举，使用字符串）
// SLEEPING: 睡眠/酒店, SHOWERS: 淋浴, STORAGE: 行李存储
// TRANSPORT: 交通, LOUNGE: 休息室, FOOD: 餐饮, SPA: SPA/按摩, WIFI: 无线网络

// 机场基础信息
model Airport {
  id           String   @id @default(cuid())
  iata         String   @unique // 例如: HND, LHR, PEK
  name         String
  city         String
  country      String
  continent    String?  // 大洲: Asia, Europe, North America, South America, Africa, Oceania
  slug         String   @unique // 例如: haneda-airport-hnd

  // SEO & 流量相关
  isPopular    Boolean  @default(false) // 是否热门机场 (Top 12 展示)
  searchVolume Int?     // 搜索量 (用于排序)

  // 关联设施（新模型）
  facilities   Facility[]

  // 保留旧字段用于数据迁移（迁移完成后可删除）
  // 1. 行李寄存数据 (JSON 格式存储: 位置、价格、营业时间)
  luggageData  String?
  // 2. 淋浴/休息数据 (JSON: 位置、是否免费、淋浴间数量)
  showerData   String?
  // 3. 睡眠/酒店数据 (JSON: 睡眠仓、24h休息区位置)
  sleepData    String?
  // 4. 交通数据 (JSON: 目的地、票价、末班车)
  transitData  String?

  updatedAt    DateTime @updatedAt
}

// 机场服务设施（统一设施模型）
model Facility {
  id              String        @id @default(cuid())
  airport         Airport       @relation(fields: [airportIata], references: [iata], onDelete: Cascade)
  airportIata     String
  
  // 基本信息
  name            String        // 设施名称（如：遨途机场中转酒店）
  nameEn          String?       // 英文名称
  terminal        String        // 航站楼（如：T1, T2, T3）
  location        String?       // 详细位置描述
  locationEn      String?       // 英文位置
  
  // 联系信息
  phone           String?
  email           String?
  website         String?
  
  // 营业时间
  hours           String?       // 营业时间描述
  is24Hours       Boolean       @default(false)
  
  // 服务类型（一个设施可提供多种服务，JSON 数组格式: ["SLEEPING", "SHOWERS"])
  services        String
  
  // 各服务的详细信息（JSON 格式，灵活存储）
  // 例如：{"sleeping": {"type": "hotel", "price": 25}, "showers": {"type": "in_room"}}
  serviceDetails  String?
  
  // 区域类型（字符串: AIRSIDE=禁区, LANDSIDE=公共区域, BOTH=两者皆有, PRIVATE=私人区域）
  areaType        String        @default("AIRSIDE")
  immigrationRequired Boolean   @default(false)    // 是否需要入境
  
  // 设施特色/标签
  features        String?       // JSON 数组，如：["淋浴", "按摩池", "叫醒服务"]
  
  // 容量信息
  capacity        String?       // 容量描述
  
  // 重要提示
  notices         String?       // JSON 数组，如：["需提前预订", "两岁以下免费"]
  
  // 数据来源
  dataSource      String?       // 数据来源（如：official, user_submitted）
  rawContent      String?       // 原始文本内容（用于参考）
  
  // 时间戳
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([airportIata])
}

// 区域类型常量说明
// AIRSIDE: 禁区/中转区（无需入境）
// LANDSIDE: 公共区域（需入境）
// BOTH: 两者皆有
// PRIVATE: 私人区域（如 CIP 航站楼）
